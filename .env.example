NODE_ENV=development
PORT=5005

# Option A — full URL (Prisma)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/serveaso

# Option B — same vars as services/payments (recommended for local monorepo dev)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=serveaso

# Remote dev example (copy from payments .env.development if you use shared DB):
# POSTGRES_HOST=13.126.11.184
# POSTGRES_DB=serveaso
