NODE_ENV=development
PORT=5005

# Comma-separated browser origins (required in production)
# CORS_ORIGINS=http://localhost:3000,https://servease-innovation.netlify.app
CORS_ORIGINS=

# Option A — full URL (Prisma)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/serveaso1

# Option B — same vars as services/payments (recommended for local monorepo dev)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=serveaso1

# Remote dev: set POSTGRES_HOST / credentials in private .env (never commit real hosts)
